---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<h1>Hi, I'm <span class="accent">Denis Seloy</span> 👋</h1>
				<p class="tagline">
					Full-stack developer passionate about building clean, performant, and user-friendly web
					applications.
				</p>
				<div class="cta-buttons">
					<a class="btn btn-primary" href="/projects">View My Work</a>
					<a class="btn btn-secondary" href="/about">About Me</a>
				</div>
			</section>

			<!-- Skills -->
			<section class="section">
				<h2>Skills &amp; Technologies</h2>
				<ul class="skills-grid">
					<li>TypeScript / JavaScript</li>
					<li>React / Next.js</li>
					<li>Astro</li>
					<li>Node.js</li>
					<li>HTML &amp; CSS</li>
					<li>SQL / PostgreSQL</li>
					<li>Git &amp; GitHub</li>
					<li>REST APIs</li>
				</ul>
			</section>

			<!-- Featured Projects -->
			<section class="section">
				<h2>Featured Projects</h2>
				<div class="projects-grid">
					<div class="project-card">
						<h3>Portfolio Website</h3>
						<p>This very site — a fast, SEO-friendly portfolio built with Astro.</p>
						<a href="/projects">See all projects →</a>
					</div>
					<div class="project-card">
						<h3>Open Source Contributions</h3>
						<p>Active contributor to open-source projects on GitHub.</p>
						<a href="https://github.com/denisseloyizz" target="_blank" rel="noopener">GitHub →</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 3em 0 2em;
	}
	.hero h1 {
		font-size: 2.8em;
		margin-bottom: 0.4em;
	}
	.accent {
		color: var(--accent);
	}
	.tagline {
		font-size: 1.15em;
		color: rgb(var(--gray));
		max-width: 560px;
		margin: 0 auto 1.6em;
	}
	.cta-buttons {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn {
		display: inline-block;
		padding: 0.6em 1.4em;
		border-radius: 6px;
		font-size: 0.95em;
		text-decoration: none;
		font-weight: 700;
		transition: opacity 0.2s;
	}
	.btn:hover {
		opacity: 0.85;
	}
	.btn-primary {
		background: var(--accent);
		color: #fff;
	}
	.btn-secondary {
		border: 2px solid var(--accent);
		color: var(--accent);
	}
	.section {
		margin-top: 3em;
	}
	.section h2 {
		font-size: 1.6em;
		margin-bottom: 1em;
		border-bottom: 2px solid rgb(var(--gray-light));
		padding-bottom: 0.3em;
	}
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 0.75em;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.skills-grid li {
		background: rgb(var(--gray-light));
		border-radius: 6px;
		padding: 0.5em 1em;
		font-size: 0.95em;
		text-align: center;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.25em;
	}
	.project-card {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		padding: 1.2em 1.4em;
		box-shadow: var(--box-shadow);
	}
	.project-card h3 {
		font-size: 1.1em;
		margin-bottom: 0.4em;
	}
	.project-card p {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin-bottom: 0.6em;
	}
</style>
